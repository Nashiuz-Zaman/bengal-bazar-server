model Order {
    id          String @id @default(uuid())
    orderNumber String

    customerName    String  @db.VarChar(255)
    customerEmail   String  @db.VarChar(255)
    customerPhone   String? @db.VarChar(20)
    billingAddress  Json? // { address, country, city, state, zipCode }
    shippingAddress Json? // { address, country, city, state, zipCode }

    couponCode   String? @db.VarChar(50)
    discount     Decimal @default(0.00) @db.Decimal(10, 2)
    tax          Decimal @default(0.00) @db.Decimal(10, 2)
    shippingFee  Decimal @default(0.00) @db.Decimal(10, 2)
    subtotal     Decimal @default(0.00) @db.Decimal(10, 2)
    total        Decimal @default(0.00) @db.Decimal(10, 2)
    totalItemQty Int     @default(0)

    // relationships
    userId       String
    user         User          @relation(fields: [userId], references: [id])
    transactions Transaction[]
    feedbacks    Feedback[]
    orderItems   OrderItem[]

    @@map("orders")
}

model OrderItem {
    id String @id @default(uuid())

    // The quantity ordered
    quantity Int @default(1)

    // --- SNAPSHOT FIELDS ---
    // These capture the state of the product at the moment of checkout
    productName        String
    variantName        String?
    sku                String
    unitSalesPrice     Decimal @db.Decimal(10, 2)
    unitDiscount       Decimal @default(0) @db.Decimal(10, 2)
    discountSalesPrice Decimal @db.Decimal(10, 2)
    image              String? // Single thumbnail URL
    attributes         Json?   @default("{}")

    // --- RELATIONSHIPS ---
    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    // We keep this to link back to the current product, 
    // but we use 'set null' or 'restrict' so history isn't lost if the product is deleted.
    variantId String?
    variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

    @@unique([orderId, variantId])
    @@map("order_items")
}
